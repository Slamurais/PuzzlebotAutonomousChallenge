<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="puzzlebot">

    <xacro:include filename="$(find puzzlebot_description)/urdf/puzzlebot_gazebo.xacro"/>
    <xacro:include filename="$(find puzzlebot_description)/urdf/puzzlebot_ros2_control.xacro"/>
   
    <xacro:property name="base_m"      value="1.2"/>
    <xacro:property name="base_i"      value="0.001"/>

    <xacro:property name="wheel_m"     value="0.053"/>
    <xacro:property name="wheel_i"     value="0.001"/>
    <xacro:property name="wheel_rad"   value="0.05"/>
    
    <xacro:property name="wheel_x"     value="0.038"/>
    <xacro:property name="wheel_y"     value="0.098"/>

    <xacro:property name="caster_m"    value="1.0E-06"/>
    <xacro:property name="caster_i"    value="1.0E-10"/>
    <xacro:property name="caster_rad"  value="0.0075"/>
    
    <xacro:property name="caster_x"    value="-0.095"/>

    <xacro:property name="blue_rgba"       value="0.0 0.5 1.0 1.0"/>
    <xacro:property name="dark_grey_rgba"  value="0.2 0.2 0.2 1.0"/>

    <!-- BASE -->
    <link name="base_footprint"/>

    <link name="base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${base_m}"/>
            <inertia ixx="${base_i}" ixy="0.0" ixz="0.0"
                     iyy="${base_i}" iyz="0.0"
                     izz="${base_i}"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/chassis.stl"/>
            </geometry>
            <material name="chassis_color">
                <color rgba="${blue_rgba}"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/chassis.stl"/>
            </geometry>
        </collision>
    </link>
    
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.05" rpy="0 0 0"/>
    </joint>

    <!-- RIGHT WHEEL -->
    <link name="wheel_right_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${wheel_m}"/>
            <inertia ixx="${wheel_i}" ixy="0.0" ixz="0.0"
                     iyy="${wheel_i}" iyz="0.0"
                     izz="${wheel_i}"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 ${-pi/2} ${pi/2}"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/wheel.stl"/>
            </geometry>
            <material name="wheel_color">
                <color rgba="${blue_rgba}"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="${wheel_rad}"/>
            </geometry>
        </collision>
    </link>

    <joint name="wheel_right_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_right_link"/>
        <axis xyz="0 1 0"/>
        <origin xyz="${wheel_x} -${wheel_y} 0" rpy="0 0 0"/>
    </joint>

    <!-- LEFT WHEEL -->
    <link name="wheel_left_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${wheel_m}"/>
            <inertia ixx="${wheel_i}" ixy="0.0" ixz="0.0"
                     iyy="${wheel_i}" iyz="0.0"
                     izz="${wheel_i}"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 ${pi/2} ${pi/2}"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/wheel.stl"/>
            </geometry>
            <material name="wheel_color">
                <color rgba="${blue_rgba}"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="${wheel_rad}"/>
            </geometry>
        </collision>
    </link>

    <joint name="wheel_left_joint" type="continuous">
        <parent link="base_link"/>
        <child link="wheel_left_link"/>
        <axis xyz="0 1 0"/>
        <origin xyz="${wheel_x} ${wheel_y} 0" rpy="0 0 0"/>
    </joint>
    
    <!-- CASTER -->
    <link name="caster_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${caster_m}"/>
            <inertia ixx="${caster_i}" ixy="0.0" ixz="0.0"
                     iyy="${caster_i}" iyz="0.0"
                     izz="${caster_i}"/>
        </inertial>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="${caster_rad}"/>
            </geometry>
        </collision>
    </link>

    <joint name="caster_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="caster_link"/>
        <origin xyz="${caster_x} 0 0.0081" rpy="0 0 0"/>
    </joint>

    <!-- LASER -->
    <link name="laser_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 ${pi}"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/laser_link.stl"/>
            </geometry>
            <material name="laser_color">
                <color rgba="${dark_grey_rgba}"/>
            </material>
        </visual>
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="base_link" />
        <child link="laser_link" />
        <origin xyz="0.038 0.0 0.115" rpy="0 0 ${pi}" />
    </joint>
    
    <!-- CAMERA -->
    <link name="camera_link">
        <visual>
            <origin xyz="0 0 0" rpy="${pi/2} 0 ${pi/2}"/>
            <geometry>
                <mesh filename="package://puzzlebot_description/meshes/camera.stl"/>
            </geometry>
            <material name="camera_color">
                <color rgba="${blue_rgba}"/>
            </material>
        </visual>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera_link"/>  
        <origin xyz="0.1 0.0 0.05" rpy="0 0 0"/> 
    </joint>

    <!-- CAMERA OPTICAL -->
    <link name="camera_optical_link"/>
    
    <joint name="camera_optical_joint" type="fixed">
        <parent link="camera_link"/>
        <child link="camera_optical_link"/>
        <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    </joint>

</robot>